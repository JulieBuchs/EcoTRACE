@article{ghaffari_power_2018,
	title = {The {Power} of {Attention}: {Using} {Eye} {Gaze} to {Predict} {Other}-{Regarding} and {Moral} {Choices}},
	volume = {29},
	issn = {0956-7976},
	shorttitle = {The {Power} of {Attention}},
	url = {https://www.jstor.org/stable/26957512},
	abstract = {According to research studying the processes underlying decisions, a two-channel mechanism connects attention and choices: top-down and bottom-up processes. To identify the magnitude of each channel, we exogenously varied information intake by systematically interrupting participants’ decision processes in Study 1 (N = 116). Results showed that participants were more likely to choose a predetermined target option. Because selection effects limited the interpretation of the results, we used a sequential-presentation paradigm in Study 2 (preregistered, N = 100). To partial out bottom-up effects of attention on choices, in particular, we presented alternatives by mirroring the gaze patterns of autonomous decision makers. Results revealed that final fixations successfully predicted choices when experimentally manipulated (bottom up). Specifically, up to 11.32\% of the link between attention and choices is driven by exogenously guided attention (1.19\% change in choices overall), while the remaining variance is explained by top-down preference formation.},
	number = {11},
	urldate = {2026-06-18},
	journal = {Psychological Science},
	publisher = {[Association for Psychological Science, Sage Publications, Inc.]},
	author = {Ghaffari, Minou and Fiedler, Susann},
	year = {2018},
	pages = {1878--1889},
	file = {JSTOR Full Text PDF:C\:\\Users\\Julie\\Zotero\\storage\\PBFUCJXN\\Ghaffari und Fiedler - 2018 - The Power of Attention Using Eye Gaze to Predict Other-Regarding and Moral Choices.pdf:application/pdf},
}

